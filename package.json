{
  "name": "react-nestjs-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@monorepo/web",
    "dev:admin": "turbo run dev --filter=@monorepo/admin",
    "dev:api": "turbo run dev --filter=@monorepo/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@monorepo/web",
    "build:admin": "turbo run build --filter=@monorepo/admin",
    "build:api": "turbo run build --filter=@monorepo/api",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
